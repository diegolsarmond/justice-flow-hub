# Supabase (obrigatório para inicialização do backend/API)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_supabase_service_role_key

# Banco (opcional): use apenas para scripts SQL manuais via psql
# Exemplo: psql "$DATABASE_URL" -f backend/sql/supabase_auth_empresa_fix.sql
DATABASE_URL=postgres://usuario:senha@host:porta/nome_db?sslmode=require

# Authentication
AUTH_TOKEN_SECRET=gerar_um_segredo_unico_e_forte

# Uazapi default credential (fallback when DB is empty)
UAZ_API_SUBDOMAIN=seu_subdominio_uaz
UAZ_API_TOKEN=token_da_uazapi
UAZ_API_CREDENTIAL_ID=uaz-default
ADMIN_TOKEN_UAZAPI=token_admin_para_gerenciar_instancia

# Configurações utilizadas pelo cliente SSE para consumir o endpoint /sse da Uazapi
UAZ_SSE_URL=
UAZ_SSE_TOKEN=
#UAZ_SSE_BASE_URL=
#UAZ_SSE_SERVER_URL=
#UAZ_API_SSE_URL=
#UAZ_API_SSE_TOKEN=
#UAZ_EVENT_TOKEN=
UAZ_SSE_ENABLED=true

# Subscription configuration
SUBSCRIPTION_TRIAL_DAYS=14
SUBSCRIPTION_GRACE_DAYS_MONTHLY=7
SUBSCRIPTION_GRACE_DAYS_ANNUAL=30
#VITE_SUBSCRIPTION_TRIAL_DAYS=14
#VITE_SUBSCRIPTION_GRACE_DAYS_MONTHLY=7
#VITE_SUBSCRIPTION_GRACE_DAYS_FALLBACK=7
# CORS
CORS_DEFAULT_ORIGINS=https://app.example.com,https://admin.example.com
#CORS_ALLOWED_ORIGINS=

# Backend Asaas integration
ASAAS_API_URL=https://www.asaas.com/api/v3
ASAAS_ACCESS_TOKEN=asaas_live_or_sandbox_token_here
ASAAS_WEBHOOK_SECRET=webhook_signature_secret_here
# Valores suportados: homologacao (padrão), producao, produção, production, prod, live
ASAAS_ENVIRONMENT=homologacao

# Opcional: substitua caso utilize ambientes separados
#VITE_API_URL=http://localhost:3001/api

# SMTP (envio de e-mails transacionais)
SMTP_HOST=smtp.seuprovedor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true
SMTP_USER=usuario@dominio.com
SMTP_PASSWORD=senha_do_smtp
SMTP_FROM=usuario@dominio.com
SMTP_FROM_NAME="Quantum JUD"
