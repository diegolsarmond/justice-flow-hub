# =============================================================================
# SERVIDOR / BACKEND
# =============================================================================
# Porta do servidor backend (padrão: 3001)
PORT=3001

# Ambiente: development | production
NODE_ENV=development

# =============================================================================
# sincronização DE DADOS
# =============================================================================
# Nomes das edge functions para sincronização
INTIMACOES_SYNC_FUNCTION_NAME=sync-intimacoes-oab
PROCESSOS_SYNC_FUNCTION_NAME=sync-processos-pdpj

# Cron schedule para sincronização automática de processos (padrão: 6h da manhã)
# Formato: https://crontab.guru/
PROCESSOS_SYNC_CRON=0 6 * * *

# =============================================================================
# CONFIGURAÇÕES DO FRONTEND (VITE)
# =============================================================================
# Nome da aplicação
VITE_APP_NAME=Quantum JUD

# Caminhos base da aplicação
VITE_APP_BASE_PATH=/
VITE_ADMIN_BASE_PATH=/admin

# URLs da API
VITE_API_BASE_URL=https://quantumtecnologia.com.br
VITE_API_URL=https://quantumtecnologia.com.br
VITE_ADMIN_API_BASE_URL=https://quantumtecnologia.com.br

# Proxy do backend (para desenvolvimento)
VITE_BACKEND_PROXY=http://localhost:3001

# Habilitar dados mockados (true | false)
VITE_ENABLE_MOCKS=true

# =============================================================================
# ASSINATURA / SUBSCRIPTION
# =============================================================================
# Dias de trial para novas assinaturas
SUBSCRIPTION_TRIAL_DAYS=14
VITE_SUBSCRIPTION_TRIAL_DAYS=14

# Dias de tolerância (grace period)
SUBSCRIPTION_GRACE_DAYS_MONTHLY=7
SUBSCRIPTION_GRACE_DAYS_ANNUAL=30
VITE_SUBSCRIPTION_GRACE_DAYS_MONTHLY=7
VITE_SUBSCRIPTION_GRACE_DAYS_FALLBACK=7

# =============================================================================
# AUTENTICAÇÃO EXTERNA
# =============================================================================
# Google OAuth (opcional)
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_SECRET=

# =============================================================================
# FTP (Opcional - para integrações de arquivo)
# =============================================================================
VITE_FTP_HOST=
VITE_FTP_PORT=21
VITE_FTP_USER=
VITE_FTP_ROOT=
VITE_FTP_SECURE=true

# =============================================================================
# CONFIGURAÇÕES AVANÇADAS / MIGRAÇÕES
# =============================================================================
# Habilitar colunas migradas na tabela de usuários (true | false)
USUARIOS_MIGRATED_COLUMNS=false

# =============================================================================
# UAZAPI (Integração WhatsApp) - ACESSADO VIA EDGE FUNCTIONS
# =============================================================================
# URL do servidor UAZAPI (usada no vite.config.ts para expose)
SERVER_URL_UAZAPI=https://quantumtecnologia.uazapi.com

